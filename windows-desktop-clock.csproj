<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>windows-desktop-clock</AssemblyName>
    <RootNamespace>DesktopClock</RootNamespace>
    <Version>1.0.0</Version>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon Condition="Exists('assets/icon.ico')">assets/icon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup Condition="Exists('assets/icon.ico')">
    <Content Include="assets/icon.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
